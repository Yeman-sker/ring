---
import BaseLayout from '../components/layout/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Calendar from '../components/Calendar.astro';
import { getPublishedPosts } from '../lib/posts';

const posts = await getPublishedPosts();
const postDates = posts.map((p) => p.data.date);
const featured = posts.slice(0, 1);
const recentPosts = posts.slice(0, 10);
---

<BaseLayout title="Ring" description="记录成长轨迹">
  <section class="hero">
    <h1>Ring</h1>
    <p class="subtitle">记录成长轨迹</p>
  </section>

  <Calendar postDates={postDates} />

  <section class="section">
    <h2 class="section-heading">最新文章</h2>
    {recentPosts.length > 0 ? (
      <>
        {featured.length > 0 && (
          <div class="featured-post">
            <PostCard post={featured[0]} variant="featured" />
          </div>
        )}
        <div class="post-grid">
          {recentPosts.map((post) => <PostCard post={post} />)}
        </div>
      </>
    ) : (
      <p class="empty">还没有文章，敬请期待。</p>
    )}
  </section>
</BaseLayout>

<style is:global>
  .featured-post {
    margin-bottom: var(--spacing-g1-5);
  }
</style>
