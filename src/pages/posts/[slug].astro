---
import { getCollection, render } from 'astro:content';
import type { Post } from '../../lib/posts';
import BaseLayout from '../../components/layout/BaseLayout.astro';

interface Props {
  post: Post;
}

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Ring`} description={post.data.summary}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.category && (
          <>
            <span class="meta-sep">·</span>
            <span class="badge">{post.data.category}</span>
          </>
        )}
        <span class="meta-sep">·</span>
        <span>{Math.ceil(((post.body?.length ?? 0) / 500) || 1)} 分钟阅读</span>
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .post {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-block: var(--spacing-v2);
  }

  .post-tags {
    margin-top: var(--spacing-g1);
    display: flex;
    gap: var(--spacing-g0-5);
    flex-wrap: wrap;
  }

  .meta-sep {
    color: var(--color-text-tertiary);
  }
</style>
