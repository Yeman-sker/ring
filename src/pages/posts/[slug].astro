---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { Post } from '../../lib/posts';
import BaseLayout from '../../components/layout/BaseLayout.astro';

interface Props {
  post: Post;
}

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Ring`} description={post.data.summary}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <time class="post-date" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="post-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: 1rem 0;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .post-tags {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-dim);
    border-radius: 999px;
  }

  .post-body {
    line-height: 1.8;
    font-size: 1rem;
  }

  .post-body :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  .post-body :global(p) {
    margin-bottom: 1rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1rem 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.25rem;
  }

  .post-body :global(pre) {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .post-body :global(code) {
    font-size: 0.875em;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 0 0 1rem;
    padding: 0.5rem 1rem;
    color: var(--muted);
    background: var(--card-bg);
    border-radius: 0 4px 4px 0;
  }

  .post-body :global(img) {
    border-radius: 6px;
  }
</style>
