---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Timeline from '../../components/Timeline.astro';
import { getTimeline, getCategories, getTags } from '../../lib/posts';

const groups = await getTimeline();
const categories = await getCategories();
const tags = await getTags();
---

<BaseLayout title="归档 — Ring">
  <h1 class="page-title">归档</h1>

  <section class="section">
    {(categories.size > 0 || tags.size > 0) && (
      <div class="taxonomies">
        {categories.size > 0 && (
          <div class="taxonomy-group">
            <h2>分类</h2>
            <div class="taxonomy-list">
              {Array.from(categories.entries()).map(([cat, count]) => (
                <a href={`/posts/category/${cat}/`} class="taxonomy-item">
                  {cat} <span class="count">{count}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        {tags.size > 0 && (
          <div class="taxonomy-group">
            <h2>标签</h2>
            <div class="taxonomy-list">
              {Array.from(tags.entries()).map(([tag, count]) => (
                <a href={`/posts/tag/${tag}/`} class="taxonomy-item">
                  {tag} <span class="count">{count}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </section>

  <Timeline groups={groups} />
</BaseLayout>

<style is:global>
  .page-title {
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-v1);
  }
</style>
